# Point the frontend to your backend base URL.
# Examples:
# - http://localhost:8000
# - http://127.0.0.1:8000
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8000

# Streaming endpoint path on the backend.
# This frontend expects a POST endpoint that streams either:
# - text/event-stream (SSE) where each `data:` line is a text chunk, OR
# - chunked text/plain where bytes arrive progressively.
NEXT_PUBLIC_BACKEND_STREAM_PATH=/chat/stream

